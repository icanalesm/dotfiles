#!/bin/sh

script="$XDG_CONFIG_HOME/shell/aliases"
[ -f "$script" ] && [ -r "$script" ] && . "$script"

script="$XDG_CONFIG_HOME/shell/colours"
[ -f "$script" ] && [ -r "$script" ] && . "$script"

case $0 in
*bash*)
	script="$XDG_CONFIG_HOME/bash/prompt" ;;
*)
	script="$XDG_CONFIG_HOME/shell/prompt" ;;
esac
[ -f "$script" ] && [ -r "$script" ] && . "$script"

unset script
